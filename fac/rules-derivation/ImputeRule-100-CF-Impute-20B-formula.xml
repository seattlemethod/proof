 <link:documentation>
     <![CDATA[if ($NetCashFlow = 0 and (not($NetCashFlowFromOperatingActivities = 0) and not($NetCashFlowFromInvestingActivities = 0) and not($NetCashFlowFromFinancingActivities = 0)) then ($NetCashFlow = $NetCashFlowFromOperatingActivities + $NetCashFlowFromInvestingActivities + $NetCashFlowFromFinancingActivities) else ($NetCashFlow = $NetCashFlow)]]>
 </link:documentation>
 <link:documentation>
     <![CDATA[If NetCashFlow = 0 and NetCashFlowFromOperatingActivities <> 0 and NetCashFlowFromInvestingActivities <> 0 and NetCashFlowFromFinancingActivities <> 0 Then
    NetCashFlow = NetCashFlowFromOperatingActivities + NetCashFlowFromInvestingActivities + NetCashFlowFromFinancingActivities
End If]]>
 </link:documentation>


